<Window x:Class="PCRemoteListener.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="PC Remote Listener" Height="600" Width="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Closing="Window_Closing"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ContextMenu x:Key="TrayMenu">
            <MenuItem Header="Show Window" Click="ShowWindow_Click"/>
            <Separator/>
            <MenuItem Header="Exit" Click="Exit_Click"/>
        </ContextMenu>

        <Storyboard x:Key="StatusPulse" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="StatusDot"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0.3" Duration="0:0:1"/>
        </Storyboard>

        <!-- Neon Colors -->
        <SolidColorBrush x:Key="NeonCyan" Color="#00d4ff"/>
        <SolidColorBrush x:Key="NeonGreen" Color="#00ff88"/>
        <SolidColorBrush x:Key="NeonPink" Color="#ff4081"/>
        <SolidColorBrush x:Key="NeonOrange" Color="#ff6600"/>
        <SolidColorBrush x:Key="NeonRed" Color="#ff0033"/>

        <!-- Rounded Neon Button Style -->
        <Style x:Key="NeonButton" TargetType="Button">
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#000" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="0">
            <!-- Title Bar -->
            <Grid Height="40" VerticalAlignment="Top" Background="#0f0f23">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="PC Remote Listener"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#e0e0e0" Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="v1.0"
                           FontSize="11" Foreground="#666"
                           VerticalAlignment="Center" HorizontalAlignment="Left"
                           Margin="150,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,8,0">
                    <Button x:Name="MinBtn" Content="─" Width="36" Height="28"
                            Background="Transparent" Foreground="#aaa"
                            FontSize="16" BorderThickness="0"
                            Click="MinBtn_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button x:Name="CloseBtn" Content="✕" Width="36" Height="28"
                            Background="Transparent" Foreground="#aaa"
                            FontSize="14" BorderThickness="0"
                            Click="CloseBtn_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <ScrollViewer Margin="0,40,0,50" VerticalScrollBarVisibility="Auto"
                          BorderThickness="0" Background="Transparent">
                <StackPanel Margin="20,16,20,20">
                    <!-- Status Card -->
                    <Border Background="#16213e" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44"
                                    Background="#0f3460" CornerRadius="22"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                 <Ellipse x:Name="StatusDot" Width="14" Height="14"
                                          Fill="#00ff88" HorizontalAlignment="Center"
                                          VerticalAlignment="Center">
                                     <Ellipse.Effect>
                                         <DropShadowEffect BlurRadius="10" ShadowDepth="0"
                                                           Color="#00ff88" Opacity="0.6"/>
                                     </Ellipse.Effect>
                                 </Ellipse>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                 <TextBlock x:Name="StatusTitle" Text="Server Running"
                                            FontSize="16" FontWeight="SemiBold"
                                            Foreground="#00d4ff"/>
                                <TextBlock x:Name="StatusSubtitle" Text="Initializing..."
                                           FontSize="12" Foreground="#888" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="2" Background="#0f3460" CornerRadius="8"
                                    Padding="12,6" VerticalAlignment="Center">
                                 <TextBlock x:Name="PortLabel" Text="Port 19090"
                                            FontSize="12" Foreground="#00d4ff"
                                            FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- TLS / Controls Card -->
                    <Border Background="#16213e" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Security" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#aaa" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="TLS Encryption"
                                           Foreground="#ccc" VerticalAlignment="Center"/>
                                 <TextBlock Grid.Column="1" x:Name="TlsStatus"
                                            Text="Enabled" Foreground="#00ff88"
                                            FontWeight="SemiBold" Margin="12,0,0,0"
                                            VerticalAlignment="Center"/>
                                 <Button Grid.Column="2" x:Name="TlsToggleBtn"
                                         Content="Disable"
                                         Background="#ff6600" Foreground="#fff"
                                         Style="{StaticResource NeonButton}"
                                         Click="TlsToggle_Click"/>
                            </Grid>
                            <TextBlock x:Name="TlsWarning" Text=""
                                       FontSize="11" Foreground="#e94560"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Instructions Card -->
                    <Border Background="#16213e" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="How to Connect" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#aaa" Margin="0,0,0,10"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#999"
                                       LineHeight="20">
1. Open PC Remote app on your Android device<LineBreak/>
2. Tap "Discover PCs on Network" or enter IP manually<LineBreak/>
3. Connect using port 19090 with TLS enabled<LineBreak/>
4. Control volume and media playback from your phone<LineBreak/>
<LineBreak/>
To disable TLS (not recommended): toggle below and restart server
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Log Card -->
                    <Border Background="#16213e" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                            MinHeight="200">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Event Log" FontSize="13"
                                           FontWeight="SemiBold" Foreground="#aaa"/>
                                 <Button Grid.Column="1" Content="Clear"
                                         Padding="12,4"
                                         Background="#2a2a4a" Foreground="#888"
                                         Style="{StaticResource NeonButton}"
                                         Click="ClearLog_Click"/>
                            </Grid>
                            <ListBox Grid.Row="1" x:Name="LogList"
                                     Background="#0f0f23" BorderThickness="0"
                                     Foreground="#ccc" FontSize="12"
                                     FontFamily="Consolas"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     VirtualizingPanel.IsVirtualizing="True">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                   Foreground="{Binding Brush}" Margin="0,1"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Height="50" VerticalAlignment="Bottom" Background="#0f0f23"
                    CornerRadius="0,0,12,12">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sebai Mohamed Safa"
                               Foreground="#555" FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="StopBtn"
                            Content="Stop Server" Margin="0,0,10,0"
                            Background="#ff0033" Foreground="#fff"
                            Style="{StaticResource NeonButton}"
                            Click="StopServer_Click"/>
                    <Button Grid.Column="2" x:Name="RestartBtn"
                            Content="Restart Server" Margin="0,0,10,0"
                            Background="#ff4081" Foreground="#fff"
                            Style="{StaticResource NeonButton}"
                            Click="RestartServer_Click"/>
                    <Button Grid.Column="3" x:Name="CopyCertBtn"
                            Content="Copy Certificate"
                            Background="#00d4ff" Foreground="#1a1a2e"
                            Style="{StaticResource NeonButton}"
                            Click="CopyCert_Click"/>
                </Grid>
            </Border>

            <!-- Tray Icon -->
            <tb:TaskbarIcon x:Name="TrayIcon"
                            ToolTipText="PC Remote Listener"
                            ContextMenu="{StaticResource TrayMenu}"/>
        </Grid>
    </Border>
</Window>
